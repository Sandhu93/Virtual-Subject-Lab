APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
WORKER_POLL_SECONDS=2
LOG_LEVEL=INFO

# The nginx frontend container proxies /api/ internally, so browser traffic
# is same-origin and never triggers CORS.  This regex covers direct API access
# via RunPod's port-8000 proxy URL (e.g. from scripts or the /docs UI).
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGIN_REGEX=https://.*\.proxy\.runpod\.net

# Internal Docker service names — do not change for standard RunPod deployment.
DATABASE_URL=postgresql+psycopg://virtual_subject:virtual_subject@postgres:5432/virtual_subject
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=virtual-subject
MINIO_SECURE=false
STORAGE_BACKEND=minio

# ── TRIBE inference ───────────────────────────────────────────────────────────
# Set TRIBE_MODE=real to run actual TRIBE v2 predictions.
# RTX 3090 (24 GB): TRIBE_DEVICE=cuda  ← recommended RunPod GPU
# A4000 (16 GB):    TRIBE_DEVICE=cuda  ← tight but works; monitor VRAM
# Anything < 16 GB: TRIBE_DEVICE=cpu   ← slow, uses system RAM
TRIBE_MODE=real
TRIBE_MODEL_ID=facebook/tribev2
TRIBE_CACHE_DIR=/app/.cache/tribe
TRIBE_DEVICE=cuda
TRIBE_UPSTREAM_VERSION=0.1.0
TRIBE_WEIGHTS_SOURCE=huggingface:facebook/tribev2

# HuggingFace token — required to download the gated LLaMA 3.2-3B component.
# Steps:
#   1. Create account at https://huggingface.co
#   2. Accept the Meta license at https://huggingface.co/meta-llama/Llama-3.2-3B
#   3. Generate a token at https://huggingface.co/settings/tokens (read access is enough)
HF_TOKEN=hf_REPLACE_ME

DEFAULT_PROJECT_NAME=Default Project
DEFAULT_USER_EMAIL=researcher@example.com
DEFAULT_USER_NAME=Researcher

OAT_VERSION=0.5.0
APP_GIT_COMMIT=unknown
