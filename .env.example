APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
WORKER_POLL_SECONDS=2
LOG_LEVEL=INFO
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DATABASE_URL=postgresql+psycopg://virtual_subject:virtual_subject@postgres:5432/virtual_subject
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=virtual-subject
MINIO_SECURE=false
STORAGE_BACKEND=minio

# TRIBE inference mode.
# mock  – deterministic synthetic predictions; no GPU or weights needed (default).
# real  – real TRIBE v2 model; requires:
#          1. pip install -r requirements-real.txt
#          2. pip install -e ".[inference]" from the upstream TRIBE repo
#          3. a CUDA GPU (or set TRIBE_DEVICE=cpu for slow CPU inference)
#          Weights download automatically from HuggingFace on first run.
TRIBE_MODE=mock
TRIBE_MODEL_ID=facebook/tribev2
TRIBE_CACHE_DIR=/app/.cache/tribe
TRIBE_DEVICE=auto
TRIBE_UPSTREAM_VERSION=0.1.0
TRIBE_WEIGHTS_SOURCE=huggingface:facebook/tribev2

DEFAULT_PROJECT_NAME=Default Project
DEFAULT_USER_EMAIL=researcher@example.com
DEFAULT_USER_NAME=Researcher

OAT_VERSION=0.5.0
APP_GIT_COMMIT=unknown
